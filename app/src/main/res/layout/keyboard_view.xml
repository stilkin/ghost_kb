<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/keyboard_background">

    <!-- Style Indicator Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp"
        android:background="@color/style_bar_background">

        <Button
            android:id="@+id/style_prev_button"
            android:layout_width="40dp"
            android:layout_height="32dp"
            android:background="@drawable/btn_style_nav"
            android:text="◀"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:padding="0dp" />

        <TextView
            android:id="@+id/style_indicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Normal"
            android:textSize="14sp"
            android:textColor="@color/style_indicator_text"
            android:gravity="center" />

        <Button
            android:id="@+id/style_next_button"
            android:layout_width="40dp"
            android:layout_height="32dp"
            android:background="@drawable/btn_style_nav"
            android:text="▶"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:padding="0dp" />
    </LinearLayout>

    <!-- Keyboard View -->
    <android.inputmethodservice.KeyboardView
        android:id="@+id/keyboard_view"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:keyTextColor="@color/key_text"
        android:keyTextSize="18sp"
        android:keyBackground="@drawable/key_background"
        android:keyPreviewLayout="@layout/key_preview"
        android:keyPreviewHeight="60dp"
        android:keyPreviewOffset="-10dp"
        android:paddingLeft="4dip"
        android:paddingRight="4dip"
        android:paddingTop="4dip"
        android:paddingBottom="4dip" />

</LinearLayout>
